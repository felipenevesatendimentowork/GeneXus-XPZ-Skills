{
  "description": "Validation cases for KB Intelligence Phase 1 using the KBExemplo parallel KB as laboratory.",
  "cases": [
    {
      "id": "case-1-webpanel-procedure-dot-call",
      "source": "WebPanel:wpRelatoriosMovimentoEstoque",
      "target": "Procedure:procPlanilhaMovimentoEstoque",
      "expected_rule": "procedure_dot_call",
      "should_exist": true,
      "expectation": "procPlanilhaMovimentoEstoque.Call(...) in effective Source must create a direct relation"
    },
    {
      "id": "case-2-procedure-direct-call",
      "source": "Procedure:PreenchXmlDocFiscal",
      "target": "Procedure:procExtraiFragmentoXml",
      "expected_rule": "procedure_direct_call",
      "should_exist": true,
      "expectation": "procExtraiFragmentoXml(...) in effective Source must create a direct relation"
    },
    {
      "id": "case-2b-procedure-direct-call-canonical-case",
      "source": "Procedure:PreenchXmlDocFiscal",
      "target": "Procedure:ProcCodigoBarrasCode128",
      "expected_rule": "procedure_direct_call",
      "should_exist": true,
      "expectation": "ProcCodigoBarrasCode128(...) must resolve to the canonical Procedure file name despite casing"
    },
    {
      "id": "case-3-comment-does-not-create-relation",
      "source": "Procedure:PreenchXmlDocFiscal",
      "target": "Procedure:procCodigoBarrasLinear2of5",
      "expected_rule": "procedure_direct_call",
      "should_exist": false,
      "expectation": "comment-only procedure reference must not create a direct relation"
    },
    {
